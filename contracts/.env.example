# ------------------------------------------------------------------------------
# Contracts (.env) — copy to .env and fill in. NEVER commit a real private key.
# ------------------------------------------------------------------------------

# Deployer key. Use a throwaway key for testnets/forks. For mainnet use a hardware
# wallet flow instead of a raw key where possible.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC endpoints
MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Etherscan key for `forge verify-contract`
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Token selection for the deploy script:
#   - MAINNET / MAINNET FORK: set the canonical mainnet USDC address below.
#   - TESTNET / local without real USDC: leave USDC_ADDRESS unset to auto-deploy a MockUSDC.
# Canonical Ethereum mainnet USDC (6 decimals):
USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
