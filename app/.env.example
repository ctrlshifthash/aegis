# ------------------------------------------------------------------------------
# Frontend (.env) — copy to app/.env. All vars are PUBLIC (shipped to the browser).
# ------------------------------------------------------------------------------

# Privy app ID (required). Create one at https://dashboard.privy.io
VITE_PRIVY_APP_ID=

# Which network this build targets:
#   1         = Ethereum mainnet (default)
#   11155111  = Sepolia testnet
VITE_CHAIN_ID=1

# Optional custom RPCs (recommended for mainnet — public RPCs rate-limit).
VITE_MAINNET_RPC_URL=
VITE_SEPOLIA_RPC_URL=

# ---- Mainnet ----
# Canonical mainnet USDC (override only if you know what you're doing).
VITE_MAINNET_USDC=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
# Pool addresses printed by the deploy script. Leave blank until deployed.
VITE_MAINNET_POOL_100=
VITE_MAINNET_POOL_1000=
VITE_MAINNET_POOL_10000=

# ---- Sepolia testnet (uses your deployed MockUSDC) ----
VITE_SEPOLIA_USDC=
VITE_SEPOLIA_POOL_100=
VITE_SEPOLIA_POOL_1000=
VITE_SEPOLIA_POOL_10000=
